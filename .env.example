# Copy to .env and fill in. Used both by `uv run python app.py` (via python-dotenv)
# and by `docker compose` (env_file + ${...} interpolation).

# --- Database (external PostgreSQL, e.g. on the NAS) ---
# DB_URL holds driver/host/port/database only; user + password are injected separately.
DB_URL=postgresql://192.168.2.230:5432/footage_archive
DB_USER=footage_archive_app                 # app role: SELECT/INSERT/UPDATE/DELETE
DB_PASSWORD=
DB_OWNER_USER=footage_archive_owner         # owner role: used by Alembic for DDL
DB_OWNER_PASSWORD=

# --- Media library ---
# ROOT_DIR is the scan root *inside the backend container* and is forced to
# /footage by docker-compose.yml. For local (non-Docker) runs set it to a path.
ROOT_DIR=./footage
MEDIA_TYPE_VIDEO=.mov,.mp4
MEDIA_TYPE_PHOTO=.jpg,.jpeg,.rw2
MEDIA_TYPE_360_VIDEO=.insv
MEDIA_TYPE_360_PHOTO=.insp,.dng
BROWSER_HIDDEN_EXTENSIONS=.xmp,.acr,.psd,.lrv,.identifier
TASK_POLL_INTERVAL_MS=5000

# --- Docker compose only ---
# Host path mounted to /footage in the backend container (Unraid: /mnt/user/footage)
FOOTAGE_DIR=./footage
# Host port the frontend (nginx) is published on -> http://<host>:8080
FRONTEND_PORT=8080
